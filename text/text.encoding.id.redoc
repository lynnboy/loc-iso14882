    [[redoc("[%@lib@member windows1254[!text_encoding]]")]]windows1254 = 2254,
    [[redoc("[%@lib@member windows1255[!text_encoding]]")]]windows1255 = 2255,
    [[redoc("[%@lib@member windows1256[!text_encoding]]")]]windows1256 = 2256,
    [[redoc("[%@lib@member windows1257[!text_encoding]]")]]windows1257 = 2257,
    [[redoc("[%@lib@member windows1258[!text_encoding]]")]]windows1258 = 2258,
    [[redoc("[%@lib@member TIS620[!text_encoding]]")]]TIS620 = 2259,
