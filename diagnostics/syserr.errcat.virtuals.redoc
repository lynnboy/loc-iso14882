[section#syserr.errcat.virtuals
    [:en] Virtual members
    [:zh_CN] 虚成员
]

[%@lib@member name[!error_category]]
[codeblock:declaration]
virtual const char* name() const noexcept = 0;
[codeblock:end]

[div:description]
[para:returns]
[:en] A string in the ordinary literal encoding naming the error category.
[:zh_CN] 命名这个错误类别的普通字面编码的字符串。
[div:end]

[%@lib@member default_error_condition[!error_category]]
[codeblock:declaration]
virtual error_condition default_error_condition(int ev) const noexcept;
[codeblock:end]

[div:description]
[para:returns]
[:en] [`error_condition(ev, *this)].
[:zh_CN] [`error_condition(ev, *this)]。
[div:end]

[%@lib@member equivalent[!error_category]]
[codeblock:declaration]
virtual bool equivalent(int code, const error_condition& condition) const noexcept;
[codeblock:end]

[div:description]
[para:returns]
[:en] [`default_error_condition(code) == condition].
[:zh_CN] [`default_error_condition(code) == condition]。
[div:end]

[%@lib@member equivalent[!error_category]]
[codeblock:declaration]
virtual bool equivalent(const error_code& code, int condition) const noexcept;
[codeblock:end]

[div:description]
[para:returns]
[:en] [`*this == code.category() && code.value() == condition].
[:zh_CN] [`*this == code.category() && code.value() == condition]。
[div:end]

[%@lib@member message[!error_category]]
[codeblock:declaration]
virtual string message(int ev) const = 0;
[codeblock:end]

[div:description]
[para:returns]
[:en] A string of multibyte characters in the execution character set
that describes the error condition denoted by [`ev].
[:zh_CN] 描述 [`ev] 所代表的错误条件的执行字符集的多字节字符串。
[div:end]
