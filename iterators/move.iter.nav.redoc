[%@lib@member operator++[!move_iterator]]
[codeblock:declaration]
constexpr move_iterator& operator++();
[codeblock:end]

[div:description]
[para:effects]
[:en] As if by [`++current].
[:zh_CN] 如同执行 [`++current]。

[para:returns]
[:en] [`*this].
[:zh_CN] [`*this]。
[div:end]

[%@lib@member operator++[!move_iterator]]
[codeblock:declaration]
constexpr void operator++(int);
[codeblock:end]

[div:description]
[para:effects]
[:en] Equivalent to [`++current].
[:zh_CN] 等价于 [`++current]。
[div:end]

