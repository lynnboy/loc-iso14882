[%@lib@member subseconds[!hh_mm_ss]]
[codeblock:declaration]
constexpr precision subseconds() const noexcept;
[codeblock:end]

[div:description]
[para:returns]
[:en] [*ss_].
[:zh_CN] [*ss_]。
[div:end]

[%@lib@member to_duration[!hh_mm_ss]]
[codeblock:declaration]
constexpr precision to_duration() const noexcept;
[codeblock:end]

[div:description]
[para:returns]
[:en] If [*is-neg], returns [`-([*h_] + [*m_] + [*s_] + [*ss_])], otherwise returns
[`[*h_] + [*m_] + [*s_] + [*ss_]].
[:zh_CN] 若 [*is-neg] 则返回 [`-([*h_] + [*m_] + [*s_] + [*ss_])]，否则返回
[`[*h_] + [*m_] + [*s_] + [*ss_]]。
[div:end]

[%@lib@member operator precision[!hh_mm_ss]]
[codeblock:declaration]
constexpr explicit operator precision() const noexcept;
[codeblock:end]

[div:description]
[para:returns]
[:en] [`to_duration()].
[:zh_CN] [`to_duration()]。
[div:end]
