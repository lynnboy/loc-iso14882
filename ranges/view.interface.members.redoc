[section#view.interface.members
    [:en] Members
    [:zh_CN] 成员
]

[%@lib@member front[!view_interface]]
[codeblock:declaration]
constexpr decltype(auto) front() requires [[redoc("`:c>")]]forward_range<D>;
constexpr decltype(auto) front() const requires [[redoc("`:c>")]]forward_range<const D>;
[codeblock:end]

[div:description]
[para:hardexpects]
[:en] [`!empty()] is [`true].
[:zh_CN] [`!empty()] 为 [`true]。

[para:effects]
[:en] Equivalent to: [`return *ranges::begin([*derived]());]
[:zh_CN] 等价于：[`return *ranges::begin([*derived]());]
[div:end]

[%@lib@member back[!view_interface]]
[codeblock:declaration]
constexpr decltype(auto) back() requires [[redoc("`:c>")]]bidirectional_range<D> && [[redoc("`:c>")]]common_range<D>;
constexpr decltype(auto) back() const
  requires [[redoc("`:c>")]]bidirectional_range<const D> && [[redoc("`:c>")]]common_range<const D>;
[codeblock:end]

[div:description]
[para:hardexpects]
[:en] [`!empty()] is [`true].
[:zh_CN] [`!empty()] 为 [`true]。

[para:effects]
[:en] Equivalent to: [`return *ranges::prev(ranges::end([*derived]()));]
[:zh_CN] 等价于：[`return *ranges::prev(ranges::end([*derived]()));]
[div:end]

[%@lib@member at[!view_interface]]
[codeblock:declaration]
template<[[redoc("`:c>")]]random_access_range R = D> requires [[redoc("`:c>")]]sized_range<R>
  constexpr decltype(auto) at(range_difference_t<R> n);
template<[[redoc("`:c>")]]random_access_range R = const D> requires [[redoc("`:c>")]]sized_range<R>
  constexpr decltype(auto) at(range_difference_t<R> n) const;
[codeblock:end]

[div:description]
[para:returns]
[:en] [`(*this)`[n`]].
[:zh_CN] [`(*this)`[n`]]。

[para:throws]
[:en] [`out_of_range] if [`n < 0] is [`true] or
[`n >= ranges::distance([*derived]())] is [`true].
[:zh_CN] 如果 [`n < 0] 为 [`true] 或者 [`n >= ranges::distance([*derived]())] 为 [`true]，
则抛出 [`out_of_range]。
[div:end]
