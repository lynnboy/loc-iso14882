[section#range.filter.sentinel
    [:en] Class template [`filter_view::[*sentinel]]
    [:zh_CN] 类模板 [`filter_view::[*sentinel]]
]

[%@lib filter_view::[*sentinel]]
[%@lib@member sentinel[!filter_view]]
[codeblock:synopsis]
namespace std::ranges {
  template<[[redoc("`:c>")]]input_range V, [[redoc("`:c>")]]indirect_unary_predicate<iterator_t<V>> Pred>
    requires [[redoc("`:c>")]]view<V> && is_object_v<Pred>
  template<bool Const>
  class filter_view<V, Pred>::[[redoc("*>")]]sentinel {
  private:
    using [[redoc("*>")]]Base = [[redoc("*>")]]maybe-const<Const, V>;                         // [=expos]
    sentinel_t<[[redoc("*>")]]Base> [[redoc("*>")]]end_ = sentinel_t<[[redoc("*>")]]Base>();                 // [=expos]
    constexpr explicit [[redoc("*>")]]sentinel([[redoc("*>")]]Parent& parent);                // \expos

  public:
    [[redoc("*>")]]sentinel() = default;
    constexpr explicit [[redoc("*>")]]sentinel(filter_view& parent);
    constexpr [[redoc("*>")]]sentinel([[redoc("*>")]]sentinel<!Const> other)
      requires Const && [[redoc("`:c>")]]convertible_to<sentinel_t<V>, sentinel_t<[[redoc("*>")]]Base>>;

    constexpr sentinel_t<[[redoc("*>")]]Base> base() const;

    template<bool OtherConst>
      requires [[redoc("`:c>")]]sentinel_for<sentinel_t<[[redoc("*>")]]Base>, iterator_t<[[redoc("*>")]]maybe-const<OtherConst, V>>>
      friend constexpr bool operator==(const [[redoc("*>")]]iterator<OtherConst>& x, const [[redoc("*>")]]sentinel& y);
  };
}
[codeblock:end]

[%@lib@ctor filter_view::[*sentinel]]
[codeblock:declaration]
constexpr [[redoc("*>")]]sentinel([[redoc("*>")]]sentinel<!Const> other)
  requires Const && [[redoc("`:c>")]]convertible_to<sentinel_t<V>, sentinel_t<[[redoc("*>")]]Base>>;
[codeblock:end]

[div:description]
[para:effects]
[:en] Initializes [*end_] with [`std::move(other.[*end_])].
[:zh_CN] 以 [`std::move(other.[*end_])] 初始化 [*end_]。
[div:end]

[%@lib@ctor filter_view::[*sentinel]]
[codeblock:declaration]
constexpr explicit [[redoc("*>")]]sentinel([[redoc("*>")]]Parent& parent);
[codeblock:end]

[div:description]
[para:effects]
[:en] Initializes [*end_] with [`ranges::end(parent.[*base_])].
[:zh_CN] 以 [`ranges::end(parent.[*base_])] 初始化 [*end_]。
[div:end]

[%@lib@member base[!filter_view::[*sentinel]]]
[codeblock:declaration]
constexpr sentinel_t<[[redoc("*>")]]Base> base() const;
[codeblock:end]

[div:description]
[para:effects]
[:en] Equivalent to: [`return [*end_];]
[:zh_CN] 等价于：[`return [*end_];]
[div:end]

[%@lib@member operator==[!filter_view::[*sentinel]]]
[codeblock:declaration]
template<bool OtherConst>
  requires [[redoc("`:c>")]]sentinel_for<sentinel_t<[[redoc("*>")]]Base>, iterator_t<[[redoc("*>")]]maybe-const <OtherConst, V>>>
  friend constexpr bool operator==(const [[redoc("*>")]]iterator<OtherConst>& x, const [[redoc("*>")]]sentinel& y);
[codeblock:end]

[div:description]
[para:effects]
[:en] Equivalent to: [`return x.[*current_] == y.[*end_];]
[:zh_CN] 等价于：[`return x.[*current_] == y.[*end_];]
[div:end]
